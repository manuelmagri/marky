<Window x:Class="Marky.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Marky"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Marky" Height="600" Width="1000"
        xmlns:vm="clr-namespace:Marky.ViewModel">


    <!-- ...  --> 
    <DockPanel>
        
        <!-- ... -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open"
                          Command="{Binding OpenFileCommand}"/>
                <MenuItem Header="Save"
                          Click="{Binding SaveFileCommand}"/>
                <MenuItem Header="Save As"
                          Click="Save_As_Click"/>
            </MenuItem>


            <MenuItem Header="Vault">
                <MenuItem Header="Open Vault" 
                          Click="Open_Vault_Click"/>
            </MenuItem>

            <MenuItem Header="View">
                <MenuItem Header="Editor only"
                          Click="Editor_Only_Click"/>
                <MenuItem Header="Preview only"
                          Click="Preview_Only_Click"/>
                <MenuItem Header="Split view"
                          Click="Split_View_Click"/>
            </MenuItem>
        </Menu>

    <Grid>
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition x:Name="Editor" Width="*" />
                <ColumnDefinition x:Name="Preview" Width="*" />
        </Grid.ColumnDefinitions>


            <TreeView Grid.Column="0"
                      ItemSource="{Binding VaultItems}}"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" /> "
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- EDITOR -->
            <TextBox x:Name="TextBox"
                 Grid.Column="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 TextChanged="{Binding EditorText, UpdateSourceTrigger=PropertyChanged}">
            </TextBox>

            <!-- PREVIEW -->
            <wv2:WebView2 x:Name="PreviewWebView"
                          Grid.Column="2">
            </wv2:WebView2>

        </Grid>
        
   </DockPanel>
    
</Window>
