            </MenuItem>


            <MenuItem Header="Vault">
                <MenuItem Header="Open Vault" 
                          Command="{Binding OpenVaultCommand}"/>
                <MenuItem Header="Create New Vault" 
                          Command="{Binding CreateVaultCommand}"/>
            </MenuItem>

            <MenuItem Header="View">
                <MenuItem Header="Editor only"
                          Click="Editor_Only_Click"/>
                <MenuItem Header="Preview only"
                          Click="Preview_Only_Click"/>
                <MenuItem Header="Split view"
                          Click="Split_View_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition x:Name="Editor" Width="*" />
                <ColumnDefinition x:Name="Preview" Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR-VAULT -->
            <TreeView x:Name="VaultTree" Grid.Column="0"
                      ItemsSource="{Binding VaultItems}"
                      helpers:TreeViewHelper.SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- EDITOR -->
            <TextBox x:Name="TextBox"
                 Grid.Column="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="14"
                 Text="{Binding EditorText, UpdateSourceTrigger=PropertyChanged}">
            </TextBox>

            <!-- PREVIEW -->
            <wv2:WebView2 x:Name="PreviewWebView" Grid.Column="2" 
                          helpers:WebView2Helper.Html="{Binding PreviewHtml}"/>

        </Grid>

    </DockPanel>

</Window>
